<included>
    <springProperty scope="context" name="MODULE_NAME" source="spring.application.name"/>
    <springProperty scope="context" name="BASE_LOG_DIR" source="logging.file.path"/>

    <property name="REQ_RES_LOG_PATTERN"
              value="${REQ_RES_LOG_PATTERN:-%d{${LOG_DATEFORMAT_PATTERN:-yyyy-MM-dd HH:mm:ss.SSS}} ${LOG_LEVEL_PATTERN:-%5p} ${PID:- } --- [%t] %-20.40logger{39} : %m%n${LOG_EXCEPTION_CONVERSION_WORD:-%wEx}}"/>
    <property name="REQ_RES_LOG_CHARSET" value="${file.encoding:-UTF-8}"/>
    <property name="REQ_RES_LOG_MAX_SIZE" value="10MB"/>
    <property name="REQ_RES_LOG_MAX_HISTORY" value="30"/>

    <appender name="FILE_REQ_RES" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <encoder>
            <charset>${REQ_RES_LOG_CHARSET}</charset>
            <pattern>${REQ_RES_LOG_PATTERN}</pattern>
        </encoder>
        <file>${BASE_LOG_DIR}/${MODULE_NAME}/req-res/req-res.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${BASE_LOG_DIR}/${MODULE_NAME}/req-res/req-res-%d{yyyy-MM-dd}.%i.log.zip</fileNamePattern>
            <maxFileSize>${REQ_RES_LOG_MAX_SIZE}</maxFileSize>
            <maxHistory>${REQ_RES_LOG_MAX_HISTORY}</maxHistory>
        </rollingPolicy>
    </appender>

    <logger name="com.breaditnow.gateway.filter.LoggingFilter" level="INFO" additivity="false">
        <appender-ref ref="FILE_REQ_RES"/>
    </logger>
</included>
